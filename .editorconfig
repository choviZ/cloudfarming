# .editorconfig
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4

[*.md]
end_of_line = lf
insert_final_newline = true

[*.java]
end_of_line = lf
insert_final_newline = true
indent_size = 4

[*.xml]
end_of_line = lf
insert_final_newline = true

[*.yml,*.yaml]
end_of_line = lf
insert_final_newline = true

[*.properties]
end_of_line = lf
insert_final_newline = true

[*.json]
end_of_line = lf
insert_final_newline = true

[*.sql]
end_of_line = lf
insert_final_newline = true

[*.sh]
end_of_line = lf
insert_final_newline = true

[*.bat,*.cmd]
end_of_line = crlf
insert_final_newline = true
